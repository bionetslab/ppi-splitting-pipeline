params {
    ppis                   = "ppis.csv"
    outdir                 = "results"
    embedding_model        = "esm2"  // "none" (one-hot), "esm2", "prot_t5", or path to pre-computed .npz
    cdhit_identity         = 0.4
    cdhit_wordsize         = 2
    seed                   = 42
    heatmap_max_per_split  = 500
    // Supply all three to skip the UniProt fetching step
    sequences              = null
    go_annotations         = null
    species                = null
    // Supply to skip the BLAST step
    blast_results          = null // all_vs_all.tsv
    // Splitting method: "kahip" (default) or "ilp"
    split_method           = "kahip"
    // Kahip parameters
    edge_weight            = "normalized_bitscore"  // "bitscore" or "normalized_bitscore"
    kahip_seed             = 1234
    kahip_k                = 3
    kahip_preconfiguration = "strong"
    // ILP parameters
    ilp_kahip_k            = 100  // number of KaHIP partitions ("clusters") fed into the ILP
    train_split            = 0.8
    val_split              = 0.1
    test_split             = 0.1
    ilp_epsilon            = 0.05
    ilp_max_sec            = 7200
    ilp_solver             = "GUROBI"
    gurobi_license         = "gurobi.lic"  // path to a gurobi.lic (e.g. WLS) file, only needed if --ilp_solver GUROBI
    // Negative sampling method: "default" (SAMPLE_NEGATIVES) or "ilp" (SAMPLE_NEGATIVES_ILP)
    negative_sampling_method = "default"
    candidate_network        = null  // optional pre-supplied candidate network CSV for the ILP negative sampler
    neg_ilp_alpha_confidence = 0.5
    neg_ilp_alpha_bias       = 0.5
    neg_ilp_lambda_degree    = 0.4
    neg_ilp_lambda_taxon_pair = 0.0
    neg_ilp_lambda_self_loop = 0.3
    neg_ilp_lambda_jaccard   = 0.3
    neg_ilp_degree_bias_mode = "unified"  // "unified" or "split"
    neg_ilp_solver           = "auto"     // "auto", "gurobi", "scip", or "highs"
    neg_ilp_time_limit       = 3600
    neg_ilp_mip_gap          = 0.01
}

process {
    cpus   = 1
    memory = '4 GB'
    time   = '2 h'

    withName: 'RUN_BLAST' {
        cpus   = 64
        memory = '32 GB'
        time   = '12 h'
    }
    withName: 'RUN_KAHIP' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
    withName: 'CDHIT2D' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
    withName: 'EMBED_SEQUENCES' {
        memory = '32 GB'
        time   = '12 h'
    }

    withName: 'TRAIN_CLASSIFIER' {
        memory = '60 GB'
        time   = '4 h'
    }

    withName: 'BIAS_ANALYSIS' {
        memory = '60 GB'
        time   = '4 h'
    }

    withName: 'SOLVE_ILP' {
        cpus   = 10
        memory = '32 GB'
        time   = '4 h'
    }

    withName: 'SAMPLE_NEGATIVES_ILP' {
        cpus   = 8
        memory = '16 GB'
        time   = '4 h'
    }
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }

    docker {
        docker.enabled = true
    }

    slurm {
        process.executor = 'slurm'
    }

    test {
        params.ppis       = "${projectDir}/data/test_ppis.csv"
        params.kahip_k     = 3
        params.ilp_kahip_k = 10
        process {
            resourceLimits = [
                cpus: 4,
                memory: '3.GB',
                time: '1.h'
            ]
        }
    }
}
