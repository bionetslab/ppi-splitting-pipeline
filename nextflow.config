plugins {
    id 'nf-schema@2.7.2'
}

params {
    samplesheet            = "samplesheet.csv"
    outdir                 = "results"
    embedding_model        = "esm2"  // "none" (one-hot), "esm2", "prot_t5", or path to pre-computed .npz
    cdhit_identity         = 0.4
    cdhit_wordsize         = 2
    seed                   = 42
    heatmap_max_per_split  = 500
    // Splitting method: "kahip" (default), "ilp", or "random" (naive baseline, see README)
    split_method           = "kahip"
    // Kahip parameters
    edge_weight            = "normalized_bitscore"  // "bitscore" or "normalized_bitscore"
    kahip_seed             = 1234
    kahip_k                = 3
    kahip_preconfiguration = "strong"
    // ILP parameters
    ilp_kahip_k            = 100  // number of KaHIP partitions ("clusters") fed into the ILP
    train_split            = 0.8
    val_split              = 0.1
    test_split             = 0.1
    ilp_epsilon            = 0.05
    ilp_max_sec            = 7200
    ilp_solver             = "GUROBI"
    gurobi_license         = "gurobi.lic"  // path to a gurobi.lic (e.g. WLS) file, only needed if --ilp_solver GUROBI
    // Negative sampling method: "default" (SAMPLE_NEGATIVES_DEGREE), "ilp" (SAMPLE_NEGATIVES_ILP),
    // or "uniform" (SAMPLE_NEGATIVES_DEGREE, uniform negatives for every split -- naive baseline, see README)
    negative_sampling_method = "default"
    neg_ilp_alpha_confidence = 0.0
    neg_ilp_alpha_bias       = 1.0
    neg_ilp_lambda_degree    = 5.0
    neg_ilp_lambda_taxon_pair = 5.0
    neg_ilp_lambda_self_loop = 0.01
    neg_ilp_lambda_jaccard   = 0.0
    neg_ilp_degree_bias_mode = "split"  // "unified" or "split"
    neg_ilp_solver           = "auto"     // "auto", "gurobi", "scip", or "highs"
    neg_ilp_time_limit       = 7200
    neg_ilp_mip_gap          = 0.01
}

process {
    cpus   = 1
    memory = '4 GB'
    time   = '2 h'
    maxRetries = 1

    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 3
    }

    // Gurobi (WLS/floating) licenses cap concurrent sessions -- cap our own
    // concurrency to that limit and back off before retrying so a transient
    // "too many sessions" failure doesn't abort the whole run.
    withLabel:gurobi {
        maxForks     = 2
        beforeScript = { task.attempt > 1 ? "sleep ${task.attempt * 30}" : '' }
    }

    withName: 'FETCH_DATA' {
        cpus   = 1
        memory = '4 GB'
        time   = '6 h'
    }

    withName: 'RUN_BLAST' {
        cpus   = 64
        memory = '32 GB'
        time   = '12 h'
    }
    withName: 'RUN_KAHIP' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
        time   = { 6.h * task.attempt }
    }
    withName: 'CDHIT2D' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
    withName: 'EMBED_SEQUENCES' {
        memory = '32 GB'
        time   = '12 h'
    }

    withName: 'TRAIN_CLASSIFIER' {
        memory = { 60.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }

    withName: 'BIAS_ANALYSIS' {
        memory = { 60.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }

    withName: 'SOLVE_ILP' {
        cpus   = 10
        memory = '32 GB'
        time   = '4 h'
    }

    withName: 'SAMPLE_NEGATIVES_ILP' {
        cpus   = 8
        memory = '16 GB'
        time   = '4 h'
    }

    withName: 'SAMPLE_NEGATIVES_DEGREE' {
        cpus   = 8
        memory = { 16.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }

    docker {
        docker.enabled = true
    }

    slurm {
        process.executor = 'slurm'
    }

    test {
        params.samplesheet = "${projectDir}/assets/samplesheet_test.csv"
        params.outdir       = "${projectDir}/results/results_test"
        process {
            resourceLimits = [
                cpus: 4,
                memory: '3.GB',
                time: '1.h'
            ]
        }
    }
}
