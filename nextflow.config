params {
    ppis                   = "ppis.csv"
    outdir                 = "results"
    embedding_model        = "esm2"  // "none" (one-hot), "esm2", "prot_t5", or path to pre-computed .npz
    cdhit_identity         = 0.4
    cdhit_wordsize         = 2
    seed                   = 42
    heatmap_max_per_split  = 500
    // Supply all three to skip the UniProt fetching step
    sequences              = null
    go_annotations         = null
    species                = null
    // Supply to skip the BLAST step
    blast_results          = null // all_vs_all.tsv
    // Splitting method: "kahip" (default) or "ilp"
    split_method           = "kahip"
    // Kahip parameters
    edge_weight            = "normalized_bitscore"  // "bitscore" or "normalized_bitscore"
    kahip_seed             = 1234
    kahip_k                = 3
    kahip_preconfiguration = "strong"
    // ILP parameters
    train_split            = 0.8
    val_split              = 0.1
    test_split             = 0.1
    ilp_epsilon            = 0.05
    ilp_max_sec            = 300
    ilp_solver             = null
}

process {
    cpus   = 1
    memory = '4 GB'
    time   = '2 h'

    withName: 'RUN_BLAST' {
        cpus   = 64
        memory = '32 GB'
        time   = '12 h'
    }
    withName: 'RUN_KAHIP' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
    withName: 'CDHIT_*' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
    withName: 'EMBED_SEQUENCES' {
        memory = '32 GB'
        time   = '12 h'
    }

    withName: 'TRAIN_CLASSIFIER' {
        memory = '60 GB'
        time   = '4 h'
    }

    withName: 'BIAS_ANALYSIS' {
        memory = '60 GB'
        time   = '4 h'
    }
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }

    docker {
        docker.enabled = true
    }

    slurm {
        process.executor = 'slurm'
    }

    test {
        params.ppis   = "${projectDir}/data/test_ppis.csv"
        params.kahip_k = 3
        process {
            resourceLimits = [
                cpus: 4,
                memory: '3.GB',
                time: '1.h'
            ]
        }
    }
}
